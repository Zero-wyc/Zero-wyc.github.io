<pre><code class="language-bash">services:
  frps_sSDC:
    image: snowdreamtech/frps:${VERSION}
    #    container_name: ${CONTAINER_NAME}
    deploy:
      resources:
        limits:
          cpus: ${CPUS}
          memory: ${MEMORY_LIMIT}
    network_mode: host
    restart: always
    volumes:
      - ${APP_PATH}/data/frps.toml:/etc/frp/frps.toml
